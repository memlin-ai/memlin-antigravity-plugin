{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__PLUGIN_DIR__/dist/hooks/session-start.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__PLUGIN_DIR__/dist/hooks/user-prompt-submit.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__PLUGIN_DIR__/dist/hooks/pre-tool-use.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__PLUGIN_DIR__/dist/hooks/post-tool-use.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__PLUGIN_DIR__/dist/hooks/stop.js\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
